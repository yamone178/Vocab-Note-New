generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       String            @id @default(cuid())
  name                     String?
  email                    String            @unique
  createdAt                DateTime          @default(now()) @map("created_at")
  updatedAt                DateTime          @updatedAt @map("updated_at")
  password                 String
  proficiencyLevel         ProficiencyLevel  @default(BEGINNER) @map("proficiency_level")
  currentDailyWordsLearned Int               @default(0) @map("current_daily_words_learned")
  dailyGoal                Int               @default(5) @map("daily_goal")
  image                    String?
  xp                       Int               @default(0)
  categories               Category[]
  interactions             UserInteraction[]
  vocabularies             Vocabulary[]

  @@map("users")
}

model Category {
  id           String       @id @default(cuid())
  name         String
  description  String?
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  userId       String       @map("userId")
  user         User         @relation(fields: [userId], references: [id])
  vocabularies Vocabulary[]

  @@map("categories")
}

model Vocabulary {
  id           String    @id @default(cuid())
  word         String
  partOfSpeech String
  definition   String
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  categoryId   String    @map("categoryId")
  userId       String    @map("userId")
  antonyms     String[]
  example      String?
  synonyms     String[]
  difficulty   String    @default("BEGINNER")
  knowIt       Boolean   @default(false) @map("know_it")
  interval     Int       @default(0)
  isMastered   Boolean   @default(false) @map("is_mastered")
  lastReview   DateTime? @map("last_review")
  nextReview   DateTime? @map("next_review")
  category     Category  @relation(fields: [categoryId], references: [id])
  user         User      @relation(fields: [userId], references: [id])

  @@map("vocabularies")
}

model UserInteraction {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  vocabularyWord  String   @map("vocabulary_word")
  interactionType String   @map("interaction_type")
  weight          Float    @default(1.0)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  user            User     @relation(fields: [userId], references: [id])

  @@unique([userId, vocabularyWord, interactionType])
  @@map("user_interactions")
}

enum ProficiencyLevel {
  BEGINNER
  PREINTERMEDIATE
  INTERMEDIATE
  UPPERINTERMEDIATE
  ADVANCED
}
