generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProficiencyLevel {
  BEGINNER
  PREINTERMEDIATE
  INTERMEDIATE
  UPPERINTERMEDIATE
  ADVANCED
}

model User {
  id               String            @id @default(cuid())
  name             String?
  email            String           @unique
  password         String
  proficiencyLevel ProficiencyLevel @default(BEGINNER) @map(name: "proficiency_level")
  createdAt        DateTime          @default(now()) @map(name: "created_at")
  updatedAt        DateTime          @updatedAt @map(name: "updated_at")

  @@map(name: "users")
}
