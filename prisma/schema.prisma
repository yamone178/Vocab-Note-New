generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProficiencyLevel {
  BEGINNER
  PREINTERMEDIATE
  INTERMEDIATE
  UPPERINTERMEDIATE
  ADVANCED
}

model User {
  id                       String            @id @default(cuid())
  name                     String?
  email                    String            @unique
  image                    String? // Add image field
  password                 String
  proficiencyLevel         ProficiencyLevel  @default(BEGINNER) @map(name: "proficiency_level")
  xp                       Int               @default(0)
  dailyGoal                Int               @default(5) @map(name: "daily_goal") // Add dailyGoal field
  currentDailyWordsLearned Int               @default(0) @map(name: "current_daily_words_learned") // Add currentDailyWordsLearned field
  createdAt                DateTime          @default(now()) @map(name: "created_at")
  updatedAt                DateTime          @updatedAt @map(name: "updated_at")
  categories               Category[]
  vocabularies             Vocabulary[]
  interactions             UserInteraction[]

  @@map(name: "users")
}

model Category {
  id           String       @id @default(cuid())
  name         String
  description  String?
  createdAt    DateTime     @default(now()) @map(name: "created_at")
  updatedAt    DateTime     @updatedAt @map(name: "updated_at")
  userId       String       @map("userId")
  user         User         @relation(fields: [userId], references: [id])
  vocabularies Vocabulary[]

  @@map(name: "categories")
}

model Vocabulary {
  id           String    @id @default(cuid())
  word         String
  partOfSpeech String
  definition   String
  example      String?
  synonyms     String[]
  antonyms     String[]
  difficulty   String    @default("BEGINNER")
  createdAt    DateTime  @default(now()) @map(name: "created_at")
  updatedAt    DateTime  @updatedAt @map(name: "updated_at")
  categoryId   String    @map("categoryId")
  category     Category  @relation(fields: [categoryId], references: [id])
  userId       String    @map("userId")
  user         User      @relation(fields: [userId], references: [id])
  knowIt       Boolean   @default(false) @map("know_it")
  lastReview   DateTime? @map(name: "last_review")
  nextReview   DateTime? @map(name: "next_review")
  interval     Int       @default(0)
  isMastered   Boolean   @default(false) @map("is_mastered")

  @@map(name: "vocabularies")
}

model UserInteraction {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id])
  vocabularyWord  String   @map("vocabulary_word") // The distinct word interacted with
  interactionType String   @map("interaction_type") // e.g., "VIEW", "SAVE", "MASTERED"
  weight          Float    @default(1.0)
  createdAt       DateTime @default(now()) @map(name: "created_at")
  updatedAt       DateTime @updatedAt @map(name: "updated_at")

  @@unique([userId, vocabularyWord, interactionType])
  @@map(name: "user_interactions")
}
